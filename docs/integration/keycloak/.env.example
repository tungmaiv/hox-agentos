# Blitz Environment Variables Template
# Copy this file to .env.local and fill in the actual values
# DO NOT commit .env.local to version control
# Realm: blitz-internal (8 teams, 5 roles, 40 employees)

# ============================================================================
# BLITZ KEYCLOAK CONFIGURATION
# Realm: blitz-internal
# Structure: 8 teams (sales, pre-sales, tech, swift, support, admin, hr, financial)
#            5 realm roles (employee, manager, team-lead, it-admin, executive)
# ============================================================================

# Keycloak realm and URLs
KEYCLOAK_REALM=blitz-internal
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_JWKS_URL=http://keycloak:8080/realms/blitz-internal/protocol/openid-connect/certs
KEYCLOAK_ISSUER=http://keycloak:8080/realms/blitz-internal

# Keycloak admin credentials
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change-me-in-production

# Keycloak database
KEYCLOAK_DB_URL=jdbc:postgresql://keycloak-db:5432/keycloak
KEYCLOAK_DB_USER=keycloak
KEYCLOAK_DB_PASSWORD=change-me-in-production

# Blitz Client Secrets (generate secure values for production)
BLITZ_PORTAL_CLIENT_SECRET=change-me-in-production
BLITZ_HULY_CLIENT_SECRET=change-me-in-production
BLITZ_KIMAI_CLIENT_SECRET=change-me-in-production

# Keycloak client for MCP servers
MCP_KEYCLOAK_CLIENT_ID=blitz-mcp
MCP_KEYCLOAK_CLIENT_SECRET=change-me-in-production

# ============================================================================
# HULY SELF-HOSTED CONFIGURATION
# See: infrastructure/huly/docker-compose.huly.yml
# ============================================================================
# Huly image version tag (check: https://github.com/hcengineering/platform/releases)
HULY_VERSION=v0.7.353

# Shared secret for Huly inter-service auth (generate: openssl rand -hex 32)
HULY_SECRET=change-me-generate-with-openssl-rand-hex-32

# CockroachDB credentials
HULY_CR_USERNAME=huly
HULY_CR_PASSWORD=change-me-in-production

# UI settings
HULY_TITLE=Blitz Huly
HULY_DEFAULT_LANGUAGE=en
HULY_LAST_NAME_FIRST=true

# Huly front service requires these integration URLs even if services not deployed
HULY_GMAIL_URL=http://localhost:8080/_gmail
HULY_CALENDAR_URL=http://localhost:8080/_calendar
HULY_TELEGRAM_URL=http://localhost:8080/_telegram
HULY_LOVE_ENDPOINT=http://localhost:8080/_love

# Huly API base URL (used by huly-mcp-server, internal Docker network)
HULY_API_BASE_URL=http://huly:8080

# Huly service account API token
HULY_API_TOKEN=your-huly-service-account-token-here

# EXPERIMENTAL: Huly OpenID Connect Configuration (Keycloak integration)
# -----------------------------------------------------------------------------
# WARNING: Huly's OpenID support has known bugs (GitHub issues #88, #94, #252):
#   - "Unknown authentication strategy 'oidc'" error
#   - last_name null constraint violations
#   - Poor documentation
#
# RECOMMENDATION: Use Shadow Registry for production stability.
# OpenID is experimental and may not work reliably.
#
# To enable: Uncomment HULY_OPENID_ISSUER
# To disable: Comment out HULY_OPENID_ISSUER (falls back to Huly native auth)
# -----------------------------------------------------------------------------
HULY_OPENID_CLIENT_ID=blitz-huly
HULY_OPENID_CLIENT_SECRET=change-me-in-production
# HULY_OPENID_ISSUER=http://keycloak:8080/realms/blitz-internal

# ============================================================================
# KIMAI BACKEND CONFIGURATION
# ============================================================================
# Kimai runs in a separate Docker Compose stack
# Start with: just kimai-up
# See: infrastructure/kimai/docker-compose.kimai.yml

# Kimai API base URL (internal Docker network)
KIMAI_API_BASE_URL=http://kimai:8001

# Kimai service account API token
KIMAI_API_TOKEN=your-kimai-service-account-token-here

# Kimai database
KIMAI_DATABASE_URL=mysql://kimai:kimai@kimai-db:3306/kimai
KIMAI_DB_PASSWORD=kimai
KIMAI_DB_ROOT_PASSWORD=root
KIMAI_APP_SECRET=change-me-in-production
KIMAI_ADMIN_EMAIL=admin@blitz.local
KIMAI_ADMIN_PASSWORD=change-me-in-production

# ============================================================================
# PORTAL CONFIGURATION
# ============================================================================
NEXT_PUBLIC_KEYCLOAK_URL=https://keycloak.lumiaitech.com
KEYCLOAK_CLIENT_ID=blitz-portal
KEYCLOAK_CLIENT_SECRET=change-me-in-production

# Portal database (shadow registry)
PORTAL_DATABASE_URL=postgresql://portal:change-me-in-production@portal-db:5432/portal
PORTAL_DB_USER=portal
PORTAL_DB_PASSWORD=change-me-in-production

# ============================================================================
# EMAIL BACKEND CONFIGURATION
# ============================================================================
EMAIL_IMAP_HOST=imap.example.com
EMAIL_IMAP_PORT=993
EMAIL_SMTP_HOST=smtp.example.com
EMAIL_SMTP_PORT=587

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_PASSWORD=change-me-in-production
REDIS_URL=redis://:change-me-in-production@redis:6379

# ============================================================================
# OLLAMA CONFIGURATION
# ============================================================================
OLLAMA_HOST=0.0.0.0
OLLAMA_MODELS_PATH=/root/.ollama/models

# ============================================================================
# SERVICE-TO-SERVICE AUTHENTICATION
# ============================================================================
MCP_SERVICE_TOKEN=change-me-generate-with-openssl-rand-hex-32
MCP_CLIENT_ID=drift-detector

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
NODE_ENV=production
LOG_LEVEL=info
ENABLE_MTLS=false
JWT_CLOCK_TOLERANCE=60
DRIFT_POLL_INTERVAL_MINUTES=5

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ============================================================================
# BLITZ INITIAL USER ACCOUNTS (Development Only)
# ============================================================================
# These users are created in the blitz-internal realm for development/testing
# DO NOT use these credentials in production
#
# Teams: sales, pre-sales, tech, swift, support, admin, hr, financial
# Roles: employee, manager, team-lead, it-admin, executive
#
# MFA Required: admin, hr-lead, hr-specialist, financial-lead, financial-analyst
#
# User Matrix:
# | Username            | Team        | Realm Role    | MFA  |
# |---------------------|-------------|---------------|------|
# | admin               | admin       | it-admin      | Yes  |
# | sales-lead          | sales       | manager       | No   |
# | sales-rep           | sales       | employee      | No   |
# | pre-sales-lead      | pre-sales   | manager       | No   |
# | pre-sales-eng       | pre-sales   | employee      | No   |
# | tech-lead           | tech        | team-lead     | No   |
# | tech-dev            | tech        | employee      | No   |
# | swift-lead          | swift       | team-lead     | No   |
# | swift-dev           | swift       | employee      | No   |
# | support-lead        | support     | manager       | No   |
# | support-agent       | support     | employee      | No   |
# | hr-lead             | hr          | manager       | Yes  |
# | hr-specialist       | hr          | employee      | Yes  |
# | financial-lead      | financial   | manager       | Yes  |
# | financial-analyst   | financial   | employee      | Yes  |
#
# Default Passwords (all temporary, must change on first login):
# - admin: admin (MFA required)
# - sales-*: Sales123!
# - pre-sales-*: PreSales123!
# - tech-*: Tech123!
# - swift-*: Swift123!
# - support-*: Support123!
# - hr-*: HR123! (MFA required)
# - financial-*: Finance123! (MFA required)

# ============================================================================
# ODOO CONFIGURATION
# ============================================================================
# Odoo runs in a separate Docker Compose stack with its own .env
# Start with: just odoo-up
# See: infrastructure/odoo/docker-compose.odoo.yml

# Odoo PostgreSQL database
ODOO_POSTGRES_DB=odoo
ODOO_POSTGRES_USER=odoo
ODOO_POSTGRES_PASSWORD=change-me-in-production

# Odoo master password (for database manager at /web/database/manager)
ODOO_ADMIN_PASSWD=change-me-in-production

# ============================================================================
# SERVICE URLS (Direct Access - No Reverse Proxy)
# ============================================================================
# All services are exposed directly on their own ports via plain HTTP:
#
# Portal:     http://localhost:3000
# Grafana:    http://localhost:3001
# Kimai:      http://localhost:8001
# Odoo:       http://localhost:8069
# Huly:       http://localhost:8080
# Keycloak:   http://localhost:8180
# Prometheus: http://localhost:9090
