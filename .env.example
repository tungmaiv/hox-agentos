# Blitz AgentOS — Environment Variables Template
# Copy this file to .env and fill in real values.
# .env is gitignored — never commit it.

# ── Database ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://blitz:CHANGE_ME@postgres/blitz
REDIS_URL=redis://redis:6379

# ── Keycloak ──────────────────────────────────────────────────
KEYCLOAK_URL=https://keycloak.blitz.local
KEYCLOAK_REALM=blitz-internal
KEYCLOAK_CLIENT_ID=blitz-agentos
KEYCLOAK_CLIENT_SECRET=CHANGE_ME

# ── Security ──────────────────────────────────────────────────
SECRET_KEY=CHANGE_ME_32_CHARS_MINIMUM
CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_32_BYTES_HEX

# ── LiteLLM Proxy ─────────────────────────────────────────────
LITELLM_URL=http://litellm:4000
LITELLM_MASTER_KEY=CHANGE_ME

# ── LLM Providers (for LiteLLM) ───────────────────────────────
ANTHROPIC_KEY=CHANGE_ME
OPENAI_KEY=CHANGE_ME
OPENROUTER_KEY=CHANGE_ME

# ── PostgreSQL (for docker-compose postgres service) ──────────
POSTGRES_PASSWORD=CHANGE_ME

# ── Application ───────────────────────────────────────────────
LOG_LEVEL=INFO
AUDIT_LOG_PATH=logs/audit.jsonl
CORS_ORIGINS=["http://localhost:3000"]
