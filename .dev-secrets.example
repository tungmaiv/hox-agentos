# Blitz AgentOS — Local Dev Secrets Template
#
# Copy this file to .dev-secrets and fill in real values.
# .dev-secrets is gitignored — never commit it.
#
# AI agents: read .dev-secrets (not this file) for actual values.
# Update .dev-secrets.example when you add a new secret shape.

# ── PostgreSQL ────────────────────────────────────────────────
POSTGRES_PASSWORD=

# ── Keycloak ──────────────────────────────────────────────────
KEYCLOAK_ADMIN_PASSWORD=

# ── E2E / Playwright Test Accounts (local auth — NOT Keycloak SSO) ────────────
# Administrator: has it-admin role, can access /admin/* pages
E2E_ADMIN_USER=admin
E2E_ADMIN_PASSWORD=
# Normal user: has employee role, no /admin/* access
E2E_USER_USER=giangtt
E2E_USER_PASSWORD=

# Legacy Keycloak test account stubs (kept for reference — Keycloak SSO optional)
# TEST_ADMIN_USER=admin@blitz.local
# TEST_EMPLOYEE_USER=employee@blitz.local

# ── LLM Providers ─────────────────────────────────────────────
LITELLM_MASTER_KEY=
ANTHROPIC_KEY=
OPENAI_KEY=
OPENROUTER_KEY=

# ── Channel Gateways ──────────────────────────────────────────
TELEGRAM_BOT_TOKEN=

# ── Internal Systems ──────────────────────────────────────────
CRM_DB_URL=

# ── Credential Encryption ─────────────────────────────────────
CREDENTIAL_ENCRYPTION_KEY=    # AES-256 key for user_credentials table

# ── Internal API (Phase 18 — Identity Configuration) ──────────
# Shared secret for Next.js → backend internal API calls
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
INTERNAL_API_KEY=
