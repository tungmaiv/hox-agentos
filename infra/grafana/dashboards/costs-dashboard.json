{
  "title": "Blitz Costs Dashboard",
  "uid": "blitz-costs",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["blitz", "costs", "litellm"],
  "panels": [
    {
      "id": 1,
      "title": "LiteLLM Spend by Model",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "sum(rate(litellm_spend_metric[1h])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "Daily Spend Total (24h)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "sum(increase(litellm_spend_metric[24h]))",
          "legendFormat": "Daily spend",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 5},
              {"color": "red", "value": 10}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Monthly Cumulative Spend (30d)",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 8,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "sum(increase(litellm_spend_metric[30d]))",
          "legendFormat": "Monthly spend",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 300}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Alert Status: Daily Spend vs $10 Threshold",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 16,
        "y": 8,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "sum(increase(litellm_spend_metric[24h])) / 10",
          "legendFormat": "Spend / Threshold",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.8},
              {"color": "red", "value": 1.0}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Token Usage by Model",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "sum(rate(litellm_total_tokens_metric[1h])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "custom": {
            "unit": "tokens/s"
          },
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Spend by User",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 12,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "sum(rate(litellm_spend_metric[1h])) by (user_id)",
          "legendFormat": "{{user_id}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    }
  ]
}
