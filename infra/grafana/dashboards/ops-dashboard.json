{
  "title": "Blitz Ops Dashboard",
  "uid": "blitz-ops",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "browser",
  "tags": ["blitz", "ops", "infrastructure"],
  "panels": [
    {
      "id": 1,
      "title": "Service Uptime",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "up{job=\"cadvisor\"}",
          "legendFormat": "cAdvisor",
          "instant": true
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "up{job=\"litellm\"}",
          "legendFormat": "LiteLLM",
          "instant": true
        },
        {
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "up{job=\"backend\"}",
          "legendFormat": "Backend",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "1": {
                  "text": "UP",
                  "color": "green",
                  "index": 0
                },
                "0": {
                  "text": "DOWN",
                  "color": "red",
                  "index": 1
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "green", "value": 1}
            ]
          },
          "unit": "short",
          "min": 0,
          "max": 1
        },
        "overrides": []
      }
    },
    {
      "id": 2,
      "title": "HTTP 5xx Error Rate",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "rate(http_server_requests_seconds_count{status=~\"5..\"}[5m])",
          "legendFormat": "{{handler}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "red", "value": 0.1}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 3,
      "title": "Container CPU Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[1m])",
          "legendFormat": "{{name}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 4,
      "title": "Container Memory Usage",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 8,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "container_memory_working_set_bytes{name!=\"\"}",
          "legendFormat": "{{name}}"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 5,
      "title": "Request Latency p95",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 0,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95 latency",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 0.5},
              {"color": "red", "value": 2.0}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 6,
      "title": "Tool Call Success Rate",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 6,
        "y": 16,
        "w": 6,
        "h": 4
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "rate(blitz_tool_calls_total{success=\"True\"}[5m]) / rate(blitz_tool_calls_total[5m])",
          "legendFormat": "Success rate",
          "instant": true
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "red", "value": null},
              {"color": "yellow", "value": 0.9},
              {"color": "green", "value": 0.99}
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 7,
      "title": "Agent Latency Trend (p50 / p95)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "blitz-prometheus"
      },
      "gridPos": {
        "x": 12,
        "y": 16,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "histogram_quantile(0.50, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p50"
        },
        {
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "blitz-prometheus"
          },
          "expr": "histogram_quantile(0.95, rate(http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "p95"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 8,
      "title": "Recent Application Logs",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "blitz-loki"
      },
      "gridPos": {
        "x": 0,
        "y": 24,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "refId": "A",
          "datasource": {
            "type": "loki",
            "uid": "blitz-loki"
          },
          "expr": "{job=\"blitz-agentos\"}",
          "queryType": "range"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      },
      "links": [
        {
          "title": "View in Explore",
          "url": "/explore?left={\"datasource\":\"blitz-loki\",\"queries\":[{\"expr\":\"{job=\\\"blitz-agentos\\\"}\",\"refId\":\"A\"}],\"range\":{\"from\":\"now-1h\",\"to\":\"now\"}}"
        }
      ]
    }
  ]
}
